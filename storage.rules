rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /documents/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /videos/{video} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /cert-snapshots/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
